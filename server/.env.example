# Server port — 3002 in dev
PORT=3002

# Set to production on the server — controls CORS and static file serving
NODE_ENV=development

# Secret used to sign admin JWTs — generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string

# Contact form — emails are sent to this address
CONTACT_EMAIL=hello@carylcomedy.com

SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
